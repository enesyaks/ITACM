# ============================================================================
# ITACM — IT Asset Control Pro: environment configuration
# Copy to .env and fill in.   NEVER commit .env to git (already ignored).
# On Vercel/Railway/Render/Fly/etc. define these same names in the platform's
# Environment Variables / Secrets UI instead of uploading a .env file.
# ============================================================================

# Which backend to use: "postgres" (self-hosted) or "firebase" (managed)
DATA_BACKEND=postgres

# HTTP port (local / Docker)
PORT=8000

# Comma-separated allowed CORS origins for your frontend
CORS_ORIGINS=http://localhost:5173

# ----------------------------------------------------------------------------
# POSTGRES MODE (DATA_BACKEND=postgres)
# ----------------------------------------------------------------------------
# With docker compose these three feed both the db container and the API URL:
POSTGRES_DB=itacm
POSTGRES_USER=itacm
POSTGRES_PASSWORD=change_me_strong_db_password

# Running the API outside compose? Point at your own Postgres instead:
DATABASE_URL=postgres://itacm:change_me_strong_db_password@localhost:5432/itacm
# If a platform integration injects POSTGRES_URL, the app can use it as a
# fallback, but DATABASE_URL is the preferred explicit name.
# POSTGRES_URL=
# For managed Postgres (Neon/Supabase/RDS) over TLS:
# PGSSL=true

# REQUIRED — JWT signing secret, min 32 chars. Generate: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_IN=12h

# First-run Admin account (created automatically when the users table is empty).
# If ADMIN_PASSWORD is left empty, a random password is generated and printed
# ONCE in the server logs (docker compose logs api).
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=IT Admin
ADMIN_PASSWORD=

# Host port mapping for docker compose (host:8000)
API_PORT=8000

# ----------------------------------------------------------------------------
# FIREBASE MODE (DATA_BACKEND=firebase)
# ----------------------------------------------------------------------------
# Provide the Firebase Admin credential ONE of these ways (in order of preference):
#
# 1) Base64-encoded JSON — best for Vercel & other PaaS secret stores:
#      base64 -i serviceAccountKey.json | tr -d '\n'
# FIREBASE_SERVICE_ACCOUNT_BASE64=
#
# 2) Raw JSON string in a single env var:
# FIREBASE_SERVICE_ACCOUNT_JSON=
#
# 3) File path for local development (keep the file OUTSIDE the repo!):
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/outside/repo/serviceAccountKey.json
#
# 4) Google Cloud runtimes with Application Default Credentials:
# FIREBASE_USE_APPLICATION_DEFAULT_CREDENTIALS=true

# Firebase *web app* config (PUBLIC, no secrets) so the built-in UI can sign
# in with the Firebase Web SDK. Firebase Console → Project settings → Your
# apps → SDK setup and configuration → Config. Paste as one-line JSON:
# FIREBASE_WEB_CONFIG={"apiKey":"...","authDomain":"...","projectId":"..."}
