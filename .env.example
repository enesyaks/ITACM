# ============================================================================
# ITACM — IT Asset Control Pro : environment configuration
# Copy to .env and fill in.   NEVER commit .env to git (already ignored).
#
# Fastest path: run `npm run setup` to generate this file with strong secrets,
# then `docker compose up -d`.
# ============================================================================

# HTTP port (local / Docker)
PORT=8000

# Extra allowed CORS origins for your frontend (blank = same-origin only)
CORS_ORIGINS=

# --- Database (docker compose fills the API URL from these three) -----------
POSTGRES_DB=itacm
POSTGRES_USER=itacm
# ⚠ CRITICAL: POSTGRES_PASSWORD is applied only when the database volume is
# FIRST created. Changing it here later and restarting will NOT work — the API
# will fail to log in. To change it safely (without losing data), run:
#     npm run change-db-password
# Never run "docker compose down -v" to "fix" it — that DELETES all your data.
POSTGRES_PASSWORD=change_me_strong_db_password

# Running the API outside compose? Point at your own Postgres instead:
DATABASE_URL=postgres://itacm:change_me_strong_db_password@localhost:5432/itacm
# For managed Postgres (Neon/Supabase/RDS) over TLS:
# PGSSL=true

# REQUIRED — JWT signing secret, min 32 chars. Generate: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_IN=12h

# First-run Admin (created automatically when the users table is empty).
# If ADMIN_PASSWORD is empty, a random one is generated and printed ONCE in the
# server logs (docker compose logs api).
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=IT Admin
ADMIN_PASSWORD=

# Host port mapping for docker compose (host:8000)
API_PORT=8000

# Uploaded document files (handover scans, repair paperwork). Docker compose
# mounts a named volume at /app/data automatically.
# DATA_DIR=/app/data
